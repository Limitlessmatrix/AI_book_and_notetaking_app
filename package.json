{
  "name": "voice-notes",
  "version": "1.0.0",
  "description": "Easy offline voice-to-text notes app — works without internet",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win nsis --x64",
    "build:win:msi": "electron-builder --win msi --x64",
    "build:win:portable": "electron-builder --win portable --x64",
    "build:win:all": "electron-builder --win --x64",
    "generate-icon": "node scripts/generate-icon.js"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "electron": "^28.3.3"
  },
  "devDependencies": {
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.voicenotes.app",
    "productName": "Voice Notes",
    "copyright": "Voice Notes App",
    "asar": true,
    "asarUnpack": [
      "node_modules/@xenova/transformers/**",
      "src/node-whisper-worker.mjs"
    ],
    "files": [
      "main.js",
      "preload.js",
      "src/**",
      "node_modules/**",
      "package.json",
      "!node_modules/.cache/**",
      "!**/*.map",
      "!**/README*",
      "!**/CHANGELOG*",
      "!**/test/**",
      "!**/tests/**",
      "!**/spec/**",
      "!**/example/**",
      "!**/examples/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "msi",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Voice Notes",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeader": null,
      "license": null,
      "runAfterFinish": true
    },
    "msi": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Voice Notes",
      "runAfterFinish": true
    },
    "portable": {
      "artifactName": "VoiceNotes-Portable.exe"
    },
    "publish": null
  },
  "keywords": [
    "voice",
    "speech-to-text",
    "notes",
    "offline"
  ],
  "author": "Voice Notes",
  "license": "MIT"
}
